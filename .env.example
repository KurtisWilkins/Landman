# Copy to .env and fill in. NEVER commit .env. Keep this file current when adding a variable.
# Values marked [DECISION] depend on an unresolved item in design doc §14.

# ── App ──────────────────────────────────────────────
APP_ENV=local                      # local | staging | production
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:5173
SECRET_KEY=change-me               # app signing secret

# ── Database (PostgreSQL + pgvector) ─────────────────
DATABASE_URL=postgresql+psycopg://rj:rj@localhost:5432/rjacq
REDIS_URL=redis://localhost:6379/0 # job queue (Arq)

# ── SHIELD (READ-ONLY SQL Server source) ─────────────  [DECISION C-14/C-15]
SHIELD_HOST=
SHIELD_PORT=1433
SHIELD_DB=
SHIELD_READONLY_USER=
SHIELD_READONLY_PASSWORD=

# ── Auth: Microsoft Entra ID (OIDC) ──────────────────  [DECISION C-16]
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
# External (PE partner) auth — magic-link or password  [DECISION C-16]
EXTERNAL_AUTH_SECRET=

# ── Object storage (S3-compatible) ───────────────────
S3_ENDPOINT=                       # blank for AWS; set for R2/MinIO
S3_REGION=us-east-1
S3_BUCKET=rjacq-files
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── AI ───────────────────────────────────────────────  [DECISION C-20]
ANTHROPIC_API_KEY=                 # also set as a GitHub repo secret for the Action
ANTHROPIC_MODEL=claude-sonnet-4-6
VOYAGE_API_KEY=                    # embeddings for GL mapping shortlist

# ── Comp intelligence (APIs where available) ─────────  [DECISION D-22]
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
TRIPADVISOR_API_KEY=
SCRAPER_PROXY_URL=                 # for sites without an API

# ── Population / demographics (ring populations) ─────  [DECISION ADR-0009]
POPULATION_PROVIDER=               # census | esri | … (blank = manual entry only)
POPULATION_PROVIDER_API_KEY=

# ── Email intake (deal mailbox) ──────────────────────  [DECISION C-18]
# Graph (M365 mailbox) …
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
DEAL_INTAKE_MAILBOX=
# … or inbound-parse provider
INBOUND_PARSE_SIGNING_SECRET=

# ── Feedback → Claude Code dispatch (GitHub) ─────────  [DECISION C-28/C-29]
GITHUB_REPO=rjourney/acquisitions  # owner/repo for issue creation
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=            # or a scoped PAT
GITHUB_WEBHOOK_SECRET=            # verify PR/issue status callbacks

# ── Observability ────────────────────────────────────  [DECISION C-30/C-31]
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
RELEASE=                          # build/commit hash, ties errors to a deploy
SLACK_ALERT_WEBHOOK_URL=          # proactive alerts
