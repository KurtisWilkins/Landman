# Copy to scripts/deploy.env (gitignored) and fill in. Sourced by provision-azure.sh.
# Never commit real secrets.

# Required
LOC=eastus2                       # Azure region (data-residency policy, ADR-0004)
PGPASSWORD=                       # strong Postgres admin password
STORAGEACCT=rjacqprodfiles        # 3-24 lowercase alphanumerics, globally unique
S3PROXY_IDENTITY=                 # S3 access key the app uses (you choose this value)
S3PROXY_CREDENTIAL=               # S3 secret key the app uses (you choose this value)
SECRET_KEY=                       # app session signing key (strong random)

# Optional overrides (defaults shown)
# RG=rjacq-prod
# ACR=rjacqprod                   # 5-50 alphanumerics, globally unique
# ENVNAME=rjacq-env
# PGSERVER=rjacq-pg
# PGADMIN=rjadmin
# PGDB=rjacq
# REDISNAME=rjacq-redis
# BLOBCONTAINER=rjacq-files
# WEB_ORIGIN=                     # https://deals.example.com once the domain is bound
# ADMIN_EMAILS=a@x.com,b@x.com    # FULL comma-separated ADMIN list (replaces, not appends)
# IMAGE_TAG=bootstrap
# SKIP_IMAGE_BUILD=0              # 1 = create apps on a placeholder; the pipeline rolls real images
